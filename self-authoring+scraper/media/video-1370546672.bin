ype":"DIALOG"}}]}}]}},"metadataRowContainer":{"metadataRowContainerRenderer":{"collapsedItemCount":0,"trackingParams":"CPUBEM2rARgBIhMIgcyn9uWSlQMVBNMRCB0o1DDq"}},"showMoreText":{"simpleText":"...more"},"showLessText":{"simpleText":"Show less"},"trackingParams":"CPUBEM2rARgBIhMIgcyn9uWSlQMVBNMRCB0o1DDq","defaultExpanded":false,"descriptionCollapsedLines":3,"showMoreCommand":{"clickTrackingParams":"CPUBEM2rARgBIhMIgcyn9uWSlQMVBNMRCB0o1DDqygEEsyE5tw==","commandExecutorCommand":{"commands":[{"clickTrackingParams":"CPUBEM2rARgBIhMIgcyn9uWSlQMVBNMRCB0o1DDqygEEsyE5tw==","changeEngagementPanelVisibilityAction":{"targetId":"engagement-panel-structured-description","visibility":"ENGAGEMENT_PANEL_VISIBILITY_EXPANDED"}},{"clickTrackingParams":"CPUBEM2rARgBIhMIgcyn9uWSlQMVBNMRCB0o1DDqygEEsyE5tw==","scrollToEngagementPanelCommand":{"targetId":"engagement-panel-structured-description"}}]}},"showLessCommand":{"clickTrackingParams":"CPUBEM2rARgBIhMIgcyn9uWSlQMVBNMRCB0o1DDqygEEsyE5tw==","changeEngagementPanelVisibilityAction":{"targetId":"engagement-panel-structured-description","visibility":"ENGAGEMENT_PANEL_VISIBILITY_HIDDEN"}},"attributedDescription":{"content":"https://www.understandmyself.com\nhttps://www.selfauthoring.com\n\nThis video describes a personality assessment and reporting system we have been working on for several years. \n\nWe launched it this week.\n\nWe believe it provides the most detailed, comprehensive description of individual personality currently available, covering the Big 5 primary traits and their 10 associated aspects:\n\nExtraversion: Assertiveness \u0026 Enthusiasm\nNeuroticism: Withdrawal \u0026 Volatility\nAgreeableness: Compassion \u0026 Politeness\nConscientiousness: Industriousness \u0026 Orderliness\nOpenness to Experience: Openness (creativity) \u0026 Intellect (interest in ideas)\n\nThis video also reviews our previous psychological intervention, www.selfauthoring.com, describing what it is and how it can be used to improve personal traits and behaviors.\n\nhttps://www.understandmyself.com\nhttps://www.selfauthoring.com\n\nWe hope you find these online projects intellectually compelling and practically useful.\n\n\nWord clouds from: http://journals.plos.org/plosone/arti...\nPew research data on polarization from: http://www.people-press.org/2017/10/0...\n\n-- SUPPORT THIS CHANNEL --\n\nDirect Support: https://www.jordanbpeterson.com/donate\nMerchandise: https://teespring.com/stores/jordanbp...\n\n-- BOOKS --\n\n12 Rules for Life: An Antidote to Chaos: https://jordanbpeterson.com/12-rules-...\nMaps of Meaning: The Architecture of Belief: https://jordanbpeterson.com/maps-of-m...\n\n-- LINKS --\n\nWebsite: https://jordanbpeterson.com/\n12 Rules for Life Tour: https://jordanbpeterson.com/events/\nBlog: https://jordanbpeterson.com/blog/\nPodcast: https://jordanbpeterson.com/podcast/\nReading List: https://jordanbpeterson.com/great-books/\nTwitter:   / jordanbpeterson  \nInstagram:   / jordan.b.peterson  \nFacebook:   / drjordanpeterson  \n\n-- PRODUCTS --\n\nPersonality Course: https://www.jordanbpeterson.com/perso...\nSelf Authoring Suite: https://selfauthoring.com/\nUnderstand Myself personality test: https://understandmyself.com/\nMerchandise: https://teespring.com/stores/jordanbp...","commandRuns":[{"startIndex":0,"length":32,"onTap":{"innertubeCommand":{"clickTrackingParams":"CPUBEM2rARgBIhMIgcyn9uWSlQMVBNMRCB0o1DDqSLCZp8y64dzD4AHKAQSzITm3","commandMetadata":{"webCommandMetadata":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqa0x5YTlDTkhiUXh2RWN2Y3J4R29GVWl1ZDhfQXxBQ3Jtc0tuNnM4cFkxbG0zbXJtZzd6RUp1QkVlckc3SHlDODBhRTFWLUZLbWlUR01rWGRBY0tfTDdQTWtYVU5GTER2SE5aQmRfMkFBUHN6T1NRY2t5UjFyWUpnUE85a01mZmVkSDdpVmJZZ0xpUm5idUV2cEcyYw\u0026q=https%3A%2F%2Fwww.understandmyself.com%2F\u0026v=4IdzC6mJzLA","webPageType":"WEB_PAGE_TYPE_UNKNOWN","rootVe":83769}},"urlEndpoint":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqa0x5YTlDTkhiUXh2