OKS --\n\n12 Rules for Life: An Antidote to Chaos: https://jordanbpeterson.com/12-rules-...\nMaps of Meaning: The Architecture of Belief: https://jordanbpeterson.com/maps-of-m...\n\n-- LINKS --\n\nWebsite: https://jordanbpeterson.com/\n12 Rules for Life Tour: https://jordanbpeterson.com/events/\nBlog: https://jordanbpeterson.com/blog/\nPodcast: https://jordanbpeterson.com/podcast/\nReading List: https://jordanbpeterson.com/great-books/\nTwitter:   / jordanbpeterson  \nInstagram:   / jordan.b.peterson  \nFacebook:   / drjordanpeterson  \n\n-- PRODUCTS --\n\nPersonality Course: https://www.jordanbpeterson.com/perso...\nSelf Authoring Suite: https://selfauthoring.com/\nUnderstand Myself personality test: https://understandmyself.com/\nMerchandise: https://teespring.com/stores/jordanbp...","commandRuns":[{"startIndex":592,"length":38,"onTap":{"innertubeCommand":{"clickTrackingParams":"CCQQ040EGAciEwiEmtWD45KVAxXOJGMBHQWdImpIgqCL7u3c29epAcoBBMkiNMk=","commandMetadata":{"webCommandMetadata":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqa2VxTHJSYmpNN2R5R0dYV2I1T1NVbzhDQk9Pd3xBQ3Jtc0tuVTFtQzZYQUFka0FKQUZ2WmxSMGt5cTFxLW04T2YtZmJ2LXRCSnAzaUU4XzU5aTJqN29NNHJYTjNFOG5paEdtWUpOMGRzOWppOVZFVjdhQ2JpbmRLclJiSTk1MTc4RFB6U3daQjdKNXhnMzdmVndRdw\u0026q=https%3A%2F%2Fwww.jordanbpeterson.com%2Fdonate\u0026v=qa9u5t3C0AI","webPageType":"WEB_PAGE_TYPE_UNKNOWN","rootVe":83769}},"urlEndpoint":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqa2VxTHJSYmpNN2R5R0dYV2I1T1NVbzhDQk9Pd3xBQ3Jtc0tuVTFtQzZYQUFka0FKQUZ2WmxSMGt5cTFxLW04T2YtZmJ2LXRCSnAzaUU4XzU5aTJqN29NNHJYTjNFOG5paEdtWUpOMGRzOWppOVZFVjdhQ2JpbmRLclJiSTk1MTc4RFB6U3daQjdKNXhnMzdmVndRdw\u0026q=https%3A%2F%2Fwww.jordanbpeterson.com%2Fdonate\u0026v=qa9u5t3C0AI","target":"TARGET_NEW_WINDOW","nofollow":true}}}},{"startIndex":644,"length":40,"onTap":{"innertubeCommand":{"clickTrackingParams":"CCQQ040EGAciEwiEmtWD45KVAxXOJGMBHQWdImpIgqCL7u3c29epAcoBBMkiNMk=","command