EWS"}},{"factoidRenderer":{"value":{"simpleText":"2017"},"label":{"simpleText":"Oct 7"},"accessibilityText":"Oct 7, 2017","backgroundColorStyle":"BACKGROUND_COLOR_STYLE_COLOR_SAMPLED","lightThemeColorPalette":{"baseBackground":4294440951,"raisedBackground":4294440951,"additiveBackground":562530183,"textPrimary":4280295456,"textSecondary":4283716692,"invertedBackground":4283716692,"overlayBackground":3424657440},"darkThemeColorPalette":{"baseBackground":4279176975,"raisedBackground":4280295456,"additiveBackground":730302343,"textPrimary":4293783021,"textSecondary":4291085508,"invertedBackground":4289111718,"overlayBackground":3424657440},"position":"FACTOID_POSITION_LAST","enableColorSampledText":true}}],"channelNavigationEndpoint":{"clickTrackingParams":"CB4Q040EGAciEwjtrIWW5JKVAxUXIgYAHQLzGCTKAQQFrS1d","commandMetadata":{"webCommandMetadata":{"url":"/@JordanBPeterson","webPageType":"WEB_PAGE_TYPE_CHANNEL","rootVe":3611,"apiUrl":"/youtubei/v1/browse"}},"browseEndpoint":{"browseId":"UCL_f53ZEJxp8TtlOkHwMV9Q","canonicalBaseUrl":"/@JordanBPeterson"}},"channelThumbnail":{"thumbnails":[{"url":"https://yt3.ggpht.com/EjQNRQGTldnH7kUHaRRWa_yOa6Po-GODJN0xqJEmsji96cAVBdLggAgHlw2DbKSvomyo3xm2CX0=s88-c-k-c0x00ffffff-no-rj"}]}}},{"expandableVideoDescriptionBodyRenderer":{"showMoreText":{"accessibility":{"accessibilityData":{"label":"Show more"}},"simpleText":"...more"},"showLessText":{"simpleText":"Show less"},"attributedDescriptionBodyText":{"content":"https://www.understandmyself.com\nhttps://www.selfauthoring.com\n\nThis video describes a personality assessment and reporting system we have been working on for several years. \n\nWe launched it this week.\n\nWe believe it provides the most detailed, comprehensive description of individual personality currently available, covering the Big 5 primary traits and their 10 associated aspects:\n\nExtraversion: Assertiveness \u0026 Enthusiasm\nNeuroticism: Withdrawal \u0026 Volatility\nAgreeableness: Compassion \u0026 Politeness\nConscientiousness: Industriousness \u0026 Orderliness\nOpenness to Experience: Openness (creativity) \u0026 Intellect (interest in ideas)\n\nThis video also reviews our previous psychological intervention, www.selfauthoring.com, describing what it is and how it can be used to improve personal traits and behaviors.\n\nhttps://www.understandmyself.com\nhttps://www.selfauthoring.com\n\nWe hope you find these online projects intellectually compelling and practically useful.\n\n\nWord clouds from: http://journals.plos.org/plosone/arti...\nPew research data on polarization from: http://www.people-press.org/2017/10/0...\n\n-- SUPPORT THIS CHANNEL --\n\nDirect Support: https://www.jordanbpeterson.com/donate\nMerchandise: https://teespring.com/stores/jordanbp...\n\n-- BOOKS --\n\n12 Rules for Life: An Antidote to Chaos: https://jordanbpeterson.com/12-rules-...\nMaps of Meaning: The Architecture of Belief: https://jordanbpeterson.com/maps-of-m...\n\n-- LINKS --\n\nWebsite: https://jordanbpeterson.com/\n12 Rules for Life Tour: https://jordanbpeterson.com/events/\nBlog: https://jordanbpeterson.com/blog/\nPodcast: https://jordanbpeterson.com/podcast/\nReading List: https://jordanbpeterson.com/great-books/\nTwitter:   / jordanbpeterson  \nInstagram:   / jordan.b.peterson  \nFacebook:   / drjordanpeterson  \n\n-- PRODUCTS --\n\nPersonality Course: https://www.jordanbpeterson.com/perso...\nSelf Authoring Suite: https://selfauthoring.com/\nUnderstand Myself personality test: https://understandmyself.com/\nMerchandise: https://teespring.com/stores/jordanbp...","commandRuns":[{"startIndex":0,"length":32,"onTap":{"innertubeCommand":{"clickTrackingParams":"CB4Q040EGAciEwjtrIWW5JKVAxUXIgYAHQLzGCRIsJmnzLrh3MPgAcoBBAWtLV0=","commandMetadata":{"webCommandMetadata":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbkxRaFZhWFFIRGpvWV9wVWp2Z2VuVEEzTXh5QXxBQ3Jtc0tsZ2dCdjExeVhDUExHRFFuNHh3UnB2ZGJVS294bHAyOC11Ul9RNGxEN2lYWm5SYU0wNGE2emNaTmNRRDJnMm91RklVaTVjOUxCO